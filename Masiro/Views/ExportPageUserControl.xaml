<UserControl x:Class="Masiro.Views.ExportPageUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Masiro.Views"
             mc:Ignorable="d">
    <Grid>
        <Canvas>
            <StackPanel
                Canvas.Left="60"
                Canvas.Top="60">
                <!-- 标题输入 -->
                <StackPanel
                    Height="40"
                    Orientation="Horizontal"
                    Margin="0,0,0,20">
                    <Label
                        Style="{StaticResource NoBorderLabel}"
                        FontSize="20"
                        VerticalContentAlignment="Center"
                        Margin="0,0,20,0">
                        标题
                    </Label>
                    <TextBox
                        x:Name="BookTitleEdit"
                        Width="300" />
                </StackPanel>
                <!-- 封面输入 -->
                <StackPanel
                    Height="40"
                    Orientation="Horizontal"
                    Margin="0,0,0,10">
                    <Label
                        Style="{StaticResource NoBorderLabel}"
                        FontSize="20"
                        VerticalContentAlignment="Center"
                        Margin="0,0,20,0">
                        封面
                    </Label>
                    <TextBox
                        x:Name="BookCoverEdit"
                        Width="300"
                        Margin="0,0,20,0" />
                    <Button
                        Click="SelectCoverButtonClick"
                        BorderThickness="1,1,1,1"
                        FontSize="20"
                        Padding="0,0,0,0"
                        Height="36"
                        Width="120">
                        选择封面
                    </Button>
                </StackPanel>
                <StackPanel
                    Margin="0,0,0,20"
                    Orientation="Horizontal">
                    <local:ImageGridUserControl
                        x:Name="ImageGridUc"
                        Margin="0,0,20,0" />
                    <local:SectionGridUserControl
                        x:Name="SectionGridUc" />
                </StackPanel>
                <StackPanel
                    Orientation="Horizontal">
                    <ProgressBar
                        x:Name="ExportProgressBar"
                        Margin="20,0,20,0"
                        Width="500" />
                    <Button
                        Click="ExportButtonClick"
                        BorderThickness="1,1,1,1"
                        FontSize="20"
                        Padding="0,0,0,0"
                        Height="36"
                        Width="120">
                        导出
                    </Button>
                </StackPanel>
            </StackPanel>
        </Canvas>
    </Grid>
</UserControl>
